# Copy to .env and fill in. Used by deploy/compose.yml.
# Der Stack läuft hinter dem zentralen Traefik (TLS/Redirects/Basic-Auth per Labels).

# --- Deploy target ------------------------------------------------------------
# Image built & pushed by GitHub Actions (linux/arm64). Use the :beta tag for the
# beta host, or pin an immutable :sha-XXXXXXX tag to roll back to a specific build.
IMAGE=ghcr.io/buterland-beckerhook/app:beta
# Public hostname der App. Muss zur Traefik-Rule unten passen.
# Beta: beta.buterland-beckerhook.de  |  Prod: buterland-beckerhook.de
PHX_HOST=beta.buterland-beckerhook.de

# --- Traefik routing ----------------------------------------------------------
# Eindeutiger Name für Router/Service/Middlewares dieses Stacks. Beta und Prod
# laufen am selben Traefik, daher unterschiedliche Namen wählen (keine Kollision).
#   Beta: bb-beta   |  Prod: bb
TRAEFIK_NAME=bb-beta
# Traefik-Host-Rule (v2-Syntax, Backticks nicht entfernen).
#   Beta: Host(`beta.buterland-beckerhook.de`)
#   Prod: Host(`buterland-beckerhook.de`, `www.buterland-beckerhook.de`)
TRAEFIK_RULE=Host(`beta.buterland-beckerhook.de`)
# Komma-separierte Middleware-Kette, die an den HTTPS-Router gehängt wird.
# Namen sind mit TRAEFIK_NAME präfixiert (siehe compose.yml).
#   Beta: ${TRAEFIK_NAME}-compress,${TRAEFIK_NAME}-auth,${TRAEFIK_NAME}-noindex
#   Prod: ${TRAEFIK_NAME}-compress,${TRAEFIK_NAME}-www
TRAEFIK_MIDDLEWARES=bb-beta-compress,bb-beta-auth,bb-beta-noindex

# Basic-Auth für Beta (leer lassen für Prod). Format: user:htpasswd-hash.
# Hash erzeugen (bcrypt):
#   docker run --rm httpd:2-alpine htpasswd -nbB beta 'PASSWORT'
# Der Wert kommt hier als Env-Variable rein -> einfaches '$' im Hash lassen
# (NICHT verdoppeln; das $$-Escaping gilt nur für inline im compose.yml).
BASIC_AUTH_USERS=

# Database
DB_USER=bbh
DB_PASSWORD=change-me

# Phoenix
SECRET_KEY_BASE=generate-with-mix-phx.gen.secret

# Web Push (generate a VAPID keypair once and keep it stable)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@buterland-beckerhook.de

# Contact form spam protection (Altcha) — a random HMAC key
ALTCHA_HMAC_KEY=

# Contact form email via the club's own SMTP
SMTP_RELAY=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
CONTACT_RECIPIENT=info@buterland-beckerhook.de
CONTACT_SENDER=noreply@buterland-beckerhook.de

# Matomo analytics (optional; leave blank to disable)
MATOMO_URL=https://matomo.verst.eu/
MATOMO_SITE_ID=
