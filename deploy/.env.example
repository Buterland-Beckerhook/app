# Reference only. DO NOT hand-fill this and rename it — run ./setup.sh instead:
# it generates every secret with openssl and writes a correct .env for you.
#
# Used by deploy/compose.yml. The stack runs behind the central Traefik
# (TLS/redirects/Basic-Auth via labels).
#
# IMPORTANT — $ escaping: Docker Compose interpolates .env values into labels and
# `environment:`, so any literal '$' in a value MUST be doubled to '$$' or it is
# mangled/truncated (this is what silently disabled Basic-Auth before). setup.sh
# handles this automatically; if you edit .env by hand, double every '$'.
#
# DATABASE_URL is NOT set here — compose.yml assembles it from DB_USER/DB_PASSWORD
# as ecto://${DB_USER}:${DB_PASSWORD}@postgres/bbh. Keep DB_PASSWORD URL-safe
# (letters/digits) so it needs no percent-encoding.

# --- Deploy target ------------------------------------------------------------
# Compose project name — also the prefix of the named volumes
# (${STACK_NAME}_postgres_data / ${STACK_NAME}_uploads). Beta and Prod run on the
# same host, so give them distinct names to keep their data separate.
#   Beta: bbh-beta   |  Prod: bbh-prod
STACK_NAME=bbh-beta
# Image built & pushed by GitHub Actions (multi-arch: linux/amd64 + linux/arm64).
# Use the :beta tag for the beta host, or pin an immutable :sha-XXXXXXX tag to
# roll back to a specific build.
IMAGE=ghcr.io/buterland-beckerhook/app:beta
# Public hostname of the app. Must match the Traefik rule below.
# Beta: beta.buterland-beckerhook.de  |  Prod: buterland-beckerhook.de
PHX_HOST=beta.buterland-beckerhook.de

# --- Traefik routing ----------------------------------------------------------
# Unique name for this stack's router/service/middlewares. Beta and Prod run on
# the same Traefik, so pick different names (no collisions).
#   Beta: bb-beta   |  Prod: bb
TRAEFIK_NAME=bb-beta
# Traefik host rule (v2 syntax, keep the backticks).
#   Beta: Host(`beta.buterland-beckerhook.de`)
#   Prod: Host(`buterland-beckerhook.de`, `www.buterland-beckerhook.de`)
TRAEFIK_RULE=Host(`beta.buterland-beckerhook.de`)
# Comma-separated middleware chain attached to the HTTPS router.
# Names are prefixed with TRAEFIK_NAME (see compose.yml).
#   Beta: ${TRAEFIK_NAME}-compress,${TRAEFIK_NAME}-auth,${TRAEFIK_NAME}-noindex
#   Prod: ${TRAEFIK_NAME}-compress,${TRAEFIK_NAME}-www
TRAEFIK_MIDDLEWARES=bb-beta-compress,bb-beta-auth,bb-beta-noindex

# Basic-Auth (Beta). Managed by setup.sh — it hashes the password with bcrypt and
# writes the value with every '$' doubled to '$$' so Compose interpolation keeps
# the hash intact. To DISABLE auth, drop the "${TRAEFIK_NAME}-auth" entry from
# TRAEFIK_MIDDLEWARES above; do NOT just empty this value (an empty, still-attached
# basicauth middleware breaks the router). Format: user:htpasswd-bcrypt-hash.
BASIC_AUTH_USERS=

# Database
DB_USER=bbh
DB_PASSWORD=change-me

# Phoenix
SECRET_KEY_BASE=generate-with-mix-phx.gen.secret

# Web Push (generate a VAPID keypair once and keep it stable)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@buterland-beckerhook.de

# Contact form spam protection (Altcha) — a random HMAC key
ALTCHA_HMAC_KEY=

# Contact form email via the club's own SMTP
SMTP_RELAY=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
CONTACT_RECIPIENT=info@buterland-beckerhook.de
CONTACT_SENDER=noreply@buterland-beckerhook.de
CONTACT_SENDER_NAME=Buterland-Beckerhook.de

# Matomo analytics (optional; leave blank to disable)
MATOMO_URL=https://matomo.verst.eu/
MATOMO_SITE_ID=

# Logging
# App log verbosity: any Elixir Logger level, from most to least verbose:
# debug|info|notice|warning|error|critical|alert|emergency. Default info. The
# /health probe log lines are emitted at debug, so info keeps them out of prod
# logs; set LOG_LEVEL=debug temporarily to see them (and everything else).
LOG_LEVEL=info
