# Copy to .env and fill in. Used by deploy/compose.yml.

# --- Deploy target ------------------------------------------------------------
# Image built & pushed by GitHub Actions. Use the :beta tag for the beta host,
# or pin an immutable :sha-XXXXXXX tag to roll back to a specific build.
IMAGE=ghcr.io/buterland-beckerhook/app:beta
# The public hostname Caddy serves and requests TLS for.
SITE_HOST=beta.buterland-beckerhook.de
# Beta => ./Caddyfile.beta (Basic-Auth + noindex). Prod => ./Caddyfile (leave unset/default).
CADDYFILE=./Caddyfile.beta
# Basic-Auth for the beta site. Generate the hash with:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'PASSWORT'
BASIC_AUTH_USER=beta
BASIC_AUTH_HASH=

# Database
DB_USER=bbh
DB_PASSWORD=change-me

# Phoenix
SECRET_KEY_BASE=generate-with-mix-phx.gen.secret
# Must match SITE_HOST. For beta: beta.buterland-beckerhook.de
PHX_HOST=beta.buterland-beckerhook.de

# Web Push (generate a VAPID keypair once and keep it stable)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@buterland-beckerhook.de

# Contact form spam protection (Altcha) — a random HMAC key
ALTCHA_HMAC_KEY=

# Contact form email via the club's own SMTP
SMTP_RELAY=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
CONTACT_RECIPIENT=info@buterland-beckerhook.de
CONTACT_SENDER=noreply@buterland-beckerhook.de

# Matomo analytics (optional; leave blank to disable)
MATOMO_URL=https://matomo.verst.eu/
MATOMO_SITE_ID=
