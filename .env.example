# =============================================================================
# Buterland-Beckerhook Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- PostgreSQL ---
DB_USER=directus
DB_PASSWORD=change-me-to-a-secure-password
DB_DATABASE=directus

# --- Directus ---
DIRECTUS_SECRET=change-me-to-a-random-secret-at-least-32-chars
ADMIN_EMAIL=admin@buterland-beckerhook.de
ADMIN_PASSWORD=change-me-admin-password
DIRECTUS_STATIC_TOKEN=change-me-to-a-random-token

# --- Directus Calendar Users ---
# These users can only create internal (non-public) events for their group
CAL_VORSTAND_PASSWORD=change-me-vorstand
CAL_OFFIZIERE_PASSWORD=change-me-offiziere
CAL_JUNGSCHUETZEN_PASSWORD=change-me-jungschuetzen
CAL_KINDERFEST_PASSWORD=change-me-kinderfest

# --- Frontend (SvelteKit) ---
DIRECTUS_URL=http://directus:8055
PUBLIC_DIRECTUS_URL=https://cms.buterland-beckerhook.de
PUBLIC_SITE_URL=https://buterland-beckerhook.de

# --- Web Push (VAPID) ---
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@buterland-beckerhook.de
